# Copy to .env and edit before running.
# Never commit .env to version control.

SECRET_KEY=change-me-to-a-long-random-string

DEBUG=True

# Postgres connection
DB_NAME=loom
DB_USER=loom
DB_PASSWORD=loom
DB_HOST=db
DB_PORT=5432

# Upload safety limits
LOOM_MAX_PDF_UPLOAD_MB=2048
LOOM_MAX_RIS_UPLOAD_MB=10
LOOM_MAX_BUNDLE_UPLOAD_MB=2048
LOOM_MAX_BUNDLE_UNCOMPRESSED_MB=2048
LOOM_MAX_BUNDLE_FILES=1000
GUNICORN_CMD_ARGS=--timeout=300
LOOM_MAX_ZIP_COMPRESSION_RATIO=200
LOOM_MAX_SCHEMA_UPLOAD_MB=1024
LOOM_MAX_ONTOLOGY_UPLOAD_MB=1024

# ---------------------------------------------------------------------------
# Production only (docker-compose.prod.yml, DJANGO_SETTINGS_MODULE=loom.settings.prod)
# ---------------------------------------------------------------------------

# Required. Comma-separated list of allowed hosts — loom.settings.prod raises
# ImproperlyConfigured at startup if this is unset or empty.
# ALLOWED_HOSTS=loom.example.com,loom.nibi.ca

# Required if Loom sits behind an HTTPS-terminating reverse proxy (the normal
# case) — needed for CSRF to accept cross-origin-looking POSTs from the
# proxy's HTTPS origin.
# CSRF_TRUSTED_ORIGINS=https://loom.example.com

# Optional. Cache backend (django-redis) — replaces the per-process, dev-only
# default so the schema/ontology update-check debounce
# (apps/schemas/views.py:_maybe_trigger_update_check) is shared across all
# gunicorn workers instead of each getting its own 12-hour window. Defaults to
# redis://cache:6379/1, matching docker-compose.prod.yml's `cache` service;
# override only if Redis isn't reachable at that address (e.g. a managed
# Redis instance).
# REDIS_URL=redis://cache:6379/1

# Optional tuning.
# DB_CONN_MAX_AGE=60
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_PRELOAD=False

# ---------------------------------------------------------------------------
# LLM proposal seam (off by default; opt in per project)
# ---------------------------------------------------------------------------
# There is no single global LLM API key setting. Each project's admin
# configures its own ProposerConfig (Project → LLM Config in the UI, or the
# ProposerConfig model directly) with `api_key_env_var` — the *name* of an
# environment variable holding that project's Anthropic API key, never the
# key itself in the database. Set whichever env var name(s) your projects
# reference here, e.g.:
# ANTHROPIC_API_KEY_PROJECT_X=sk-ant-...
# See docs/admin-guide.md#configuring-the-llm-pipeline.
