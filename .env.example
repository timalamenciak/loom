# Copy to .env and edit before running.
# Never commit .env to version control.

SECRET_KEY=change-me-to-a-long-random-string

DEBUG=True

# Postgres connection
DB_NAME=loom
DB_USER=loom
DB_PASSWORD=loom
DB_HOST=db
DB_PORT=5432

# Upload safety limits
LOOM_MAX_PDF_UPLOAD_MB=100
LOOM_MAX_RIS_UPLOAD_MB=10
LOOM_MAX_BUNDLE_UPLOAD_MB=500
LOOM_MAX_BUNDLE_UNCOMPRESSED_MB=1000
LOOM_MAX_BUNDLE_FILES=1000
LOOM_MAX_ZIP_COMPRESSION_RATIO=200

# Optional: comma-separated list of allowed hosts (prod only)
# ALLOWED_HOSTS=loom.example.com,loom.nibi.ca
# CSRF_TRUSTED_ORIGINS=https://loom.example.com
# DB_CONN_MAX_AGE=60
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_PRELOAD=False
