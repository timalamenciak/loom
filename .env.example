# Copy to .env and edit before running.
# Never commit .env to version control.

SECRET_KEY=change-me-to-a-long-random-string

DEBUG=True

# Postgres connection
DB_NAME=loom
DB_USER=loom
DB_PASSWORD=loom
DB_HOST=db
DB_PORT=5432

# Optional: comma-separated list of allowed hosts (prod only)
# ALLOWED_HOSTS=loom.example.com,loom.nibi.ca
